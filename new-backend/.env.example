# Porta do backend (sobrescreve config.json -> portaBackend)
PORT=3001

# JWT_SECRET (opcional)
# Se nao definido, o backend gera automaticamente um segredo seguro
# em data/secrets.json no primeiro boot. Defina aqui apenas se quiser
# controlar o segredo via variavel de ambiente.
# JWT_SECRET=

# Habilita criacao automatica do usuario padrao seven/seven100 (apenas dev)
# Em producao mantenha desligado e use o fluxo de setup inicial.
# ALLOW_DEFAULT_USER=false
